{
  "version": 2,
  "builds": [
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "^/$", "status": 302, "headers": { "Location": "/miniapp/" } },
    { "src": "^/miniapp/?$", "dest": "/miniapp/index.html" },
    { "src": "^/miniapp/(.*)$", "dest": "/miniapp/$1" },
    { "src": "^/content/(.*)$", "dest": "/content/$1" }
  ]
}

