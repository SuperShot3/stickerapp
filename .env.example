# Copy to .env and fill in values. Never commit .env.
BOT_TOKEN=your_bot_token_from_botfather
BOT_SECRET=random_hmac_secret_for_invoice_payloads

# Comma-separated Telegram user IDs allowed to run /refund (admin)
ADMIN_TELEGRAM_IDS=123456789

# Optional: HTTPS URL for Mini App (set in @BotFather → Bot Settings → Menu Button / Web App)
MINI_APP_URL=https://your-domain.example/miniapp/

# Local Mini App static server (set false if port conflicts and you only test the bot)
MINIAPP_ENABLED=true
MINIAPP_PORT=8080

# Monetization: set true to enable Telegram Stars payments (/buy, invoices, refunds)
PAYMENTS_ENABLED=false

# Database (SQLite path relative to project root)
DATABASE_URL=sqlite+aiosqlite:///./data/stickerbot.db

# Background removal order: 1) rembg (local, free)  2) remove.bg  3) OpenAI (last resort)
REMOVE_BG_ENABLED=true

# remove.bg — best paid option for hard photos (https://www.remove.bg/api)
REMOVE_BG_API_KEY=

# OpenAI — only used if rembg + remove.bg fail (BG removal prompt, not image generation)
AI_API_KEY=
AI_API_URL=
AI_IMAGE_MODEL=gpt-image-1.5
AI_BG_FALLBACK_ENABLED=true
# Optional: custom BG-only prompt (leave empty for built-in)
AI_EDIT_PROMPT=
# Optional USD estimates for admin /apicost (per 1M tokens — see openai.com/api/pricing)
AI_USD_PER_1M_INPUT_TOKENS=8
AI_USD_PER_1M_OUTPUT_TOKENS=32
# remove.bg: set your plan's $/credit (0 = show credits only, no $ estimate)
REMOVEBG_USD_PER_CREDIT=0

# Testing: everyone gets at least this many credits (set 0 for production)
FREE_CREDITS_GRANT=500

# Local background removal (pip install rembg) — no API key
REMOVE_BG_ENABLED=true
